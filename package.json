{
  "name": "cortex-lattice",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "prisma generate && next build",
    "start": "next start -p 3001",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:backup": "docker exec cortex-postgres pg_dump -U cortex cortex_lattice > backups/backup-$(date +%Y%m%d-%H%M%S).sql",
    "db:restore": "docker exec -i cortex-postgres psql -U cortex cortex_lattice < ",
    "postinstall": "prisma generate",
    "generate": "npx tsx scripts/generate-problem.ts",
    "generate:batch": "npx tsx scripts/generate-problem.ts --batch"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@auth/prisma-adapter": "^2.11.1",
    "@codemirror/lang-python": "^6.1.0",
    "@codemirror/state": "^6.4.0",
    "@codemirror/theme-one-dark": "^6.1.0",
    "@codemirror/view": "^6.24.0",
    "@hookform/resolvers": "^5.2.2",
    "@monaco-editor/react": "^4.6.0",
    "@prisma/client": "^5.9.0",
    "bcryptjs": "^3.0.3",
    "codemirror": "^6.0.1",
    "framer-motion": "^11.0.0",
    "glob": "^10.3.10",
    "lucide-react": "^0.312.0",
    "next": "^14.1.0",
    "next-auth": "^5.0.0-beta.30",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.71.1",
    "yaml": "^2.3.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "eslint": "^8",
    "eslint-config-next": "14.1.0",
    "postcss": "^8",
    "prisma": "^5.9.0",
    "tailwindcss": "^3.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
